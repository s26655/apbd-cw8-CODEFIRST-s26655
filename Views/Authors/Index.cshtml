@model IEnumerable<CourseLibrary.Models.Author>

@{
    ViewData["Title"] = "Authors";
}

<h1>Authors</h1>

<table class="table">
    <thead>
        <tr>
            <th>First name</th>
            <th>Last name</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var author in Model)
    {
        <tr>
            <td>@author.FirstName</td>
            <td>@author.LastName</td>
        </tr>
    }
    </tbody>
</table>